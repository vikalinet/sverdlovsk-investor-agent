# ============================================================
# Investor Agent - Переменные окружения
# Копируйте этот файл в .env и заполните значения
# ============================================================

# ==================== Приложение ====================
# Окружение: development, production, testing
ENVIRONMENT=development

# Отладка (включена в development)
DEBUG=True

# Секретный ключ (минимум 32 символа)
# В production обязательно сгенерируйте новый!
SECRET_KEY=dev-secret-key-not-for-production-change-in-prod

# ==================== MCP Server URLs ====================
# URLs для подключения к MCP серверам (опционально)
MCP_SUPPORT_MEASURES_URL=
MCP_INVESTMENT_OBJECTS_URL=
MCP_BUSINESS_REGISTRY_URL=

# ==================== API Keys ====================
# Поисковые API (для production использования)
SEARCH_API_KEY=
SEARCH_PROVIDER=mock  # mock, yandex, google

YANDEX_XML_API_KEY=your_yandex_api_key_here
YANDEX_XML_CLIENT_ID=your_yandex_client_id_here

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here

BING_API_KEY=your_bing_api_key_here

# ==================== Database ====================
# Development: SQLite
DATABASE_URL=sqlite+aiosqlite:///data/dev.db

# Production: PostgreSQL (раскомментировать для production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/investor_agent

# Пути к базам данных MCP (опционально)
SUPPORT_MEASURES_DB=mcp_servers/data/support_measures.db
INVESTMENT_OBJECTS_DB=mcp_servers/data/investment_objects.db
BUSINESS_REGISTRY_DB=mcp_servers/data/business_registry.db

# ==================== Web Interface ====================
# Flask настройки
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_WORKERS=4

# CORS Origins (в production укажите конкретные домены)
WEB_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# ==================== Логирование ====================
# Уровень: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ==================== Кэширование ====================
# Тип: simple, redis, memcached
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# Redis (для production)
# CACHE_TYPE=redis
# REDIS_URL=redis://localhost:6379/0

# ==================== Безопасность ====================
# Rate limiting (запросов в минуту)
RATE_LIMIT_PER_MINUTE=60

# Заголовок для API ключа
API_KEY_HEADER=X-API-Key

# ==================== Регион ====================
REGION_NAME=Свердловская область
REGION_CODE=66
REGION_CAPITAL=Екатеринбург

# ==================== ML Model ====================
# Путь к сохранённой модели (опционально)
ML_MODEL_PATH=ml_models/saved/applicability_model.pkl

# ==================== Документы ====================
# Директории для документов
DOCUMENTS_DIR=output/documents
TEMPLATES_DIR=templates/documents

# ==================== Аналитика ====================
# Минимальная сумма инвестиций
MIN_INVESTMENT_AMOUNT=10000000

# Максимальный срок окупаемости (лет)
MAX_PAYBACK_PERIOD=5
